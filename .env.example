# Required — Veriphone phone validation API key
VERIPHONE_API_KEY=

# Required — PostgreSQL connection string (used for rate limiting, sessions, auth)
DATABASE_URL=

# Required — Express session secret (use a long random string)
SESSION_SECRET=

# Required — Web3Forms access key for contact form
WEB3FORMS_ACCESS_KEY=

# Optional — Developer docs password (if unset, docs are open)
DEV_DOCS_PASSWORD=

# Optional — Comma-separated valid API keys for X-API-Key header auth
TRUEREACH_API_KEYS=

# Optional — PayPal integration
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Optional — Comma-separated allowed CORS origins
ALLOWED_ORIGINS=https://true-reach.app,https://www.true-reach.app

# Optional — Rate limit configuration
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Optional — Per-org daily validation cap (default 10000)
ORG_DAILY_VALIDATION_LIMIT=10000

# Optional — Port (defaults to 5000)
PORT=5000
